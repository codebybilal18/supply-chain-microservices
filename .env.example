# =============================================================================
# SupplyChainForge — Root Environment Variables
# Copy this to .env and fill in real values. NEVER commit .env
# =============================================================================

# ── Inventory Service ─────────────────────────────────────────────────────────
INVENTORY_SERVICE_PORT=8001

# ── Order Service ─────────────────────────────────────────────────────────────
ORDER_SERVICE_PORT=8002

# ── Fulfillment Service ───────────────────────────────────────────────────────
FULFILLMENT_SERVICE_PORT=8003

# ── MySQL (shared root password for local dev only) ───────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword_change_me

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
