# =============================================================================
# Inventory Service — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env
# =============================================================================

# ── Service Identity ──────────────────────────────────────────────────────────
SERVICE_NAME=inventory-service
SERVICE_VERSION=1.0.0
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
# In Docker Compose, DB_HOST is the service name (mysql).
# Locally, use 127.0.0.1 if running MySQL outside Docker.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=inventory_user
DB_PASSWORD=inventory_password
DB_NAME=inventory_db

# Connection pool tuning (sane defaults; raise for high-traffic)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ── Cache (Redis — used from Phase 2) ────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# ── GCP (used from Phase 4) ───────────────────────────────────────────────────
# GCP_PROJECT_ID=your-gcp-project-id
# PUBSUB_EMULATOR_HOST=localhost:8085
