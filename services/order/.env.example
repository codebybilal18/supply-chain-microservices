# =============================================================================
# Order Service — Environment Variables (.env.example)
# =============================================================================

SERVICE_NAME=order-service
SERVICE_VERSION=1.0.0
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=order_user
DB_PASSWORD=order_password
DB_NAME=order_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ── Inter-service URLs ────────────────────────────────────────────────────────
# In Docker Compose:  http://inventory:8000
# In Cloud Run:       https://inventory-<hash>.run.app
INVENTORY_SERVICE_URL=http://inventory:8000

# ── GCP / Pub/Sub ─────────────────────────────────────────────────────────────
GCP_PROJECT_ID=
PUBSUB_EMULATOR_HOST=
PUBSUB_TOPIC_ORDER_EVENTS=order-events
PUBSUB_SUBSCRIPTION_FULFILLMENT_ASSIGNED=order-fulfillment-assigned-sub
